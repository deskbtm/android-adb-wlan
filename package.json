{
  "name": "android-adb-wlan",
  "displayName": "Android ADB WLAN — Wireless Debugging",
  "description": "Connect Android phones to ADB over Wi-Fi. Wireless debugging, QR pairing (Android 11+), adb connect/pair, USB tcpip, multi-device picker, and mDNS reconnect for cross-platform mobile dev: React Native, Flutter, Expo, Capacitor, and native Android.",
  "version": "0.0.12",
  "icon": "android.png",
  "license": "MIT",
  "publisher": "HanWang",
  "homepage": "https://github.com/deskbtm/android-adb-wlan#readme",
  "bugs": {
    "url": "https://github.com/deskbtm/android-adb-wlan/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deskbtm/android-adb-wlan"
  },
  "galleryBanner": {
    "color": "#1B3A2D",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.42.0",
    "yarn": "Please use npm",
    "pnpm": "Please use npm"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "android",
    "adb",
    "adb wifi",
    "adb wireless",
    "wireless debugging",
    "wireless adb",
    "android debug bridge",
    "adb connect",
    "adb pair",
    "adb tcpip",
    "wifi",
    "wi-fi",
    "wlan",
    "qr code",
    "qr pairing",
    "pair device",
    "android 11",
    "android device",
    "phone",
    "mobile",
    "device picker",
    "mdns",
    "platform-tools",
    "cross-platform",
    "cross platform",
    "multiplatform",
    "mobile development",
    "react native",
    "flutter",
    "expo",
    "capacitor",
    "ionic",
    "uni-app",
    "taro",
    "native android",
    "developer options"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "android.adb.connect",
        "title": "Connect over Wi-Fi",
        "category": "ADB WLAN",
        "icon": {
          "dark": "assets/adb.svg",
          "light": "assets/adb.svg"
        }
      },
      {
        "command": "android.adb.restart",
        "title": "Restart ADB Server",
        "category": "ADB WLAN"
      },
      {
        "command": "android.adb.devices",
        "title": "Show Connected Devices",
        "category": "ADB WLAN"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "android.adb.connect",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "lint": "eslint src --ext ts",
    "watch": "tsc --watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "mocha --ui tdd out/test/suite/parsers.test.js out/test/suite/pairingCredentials.test.js",
    "test:integration": "node ./out/test/runTest.js",
    "package": "vsce package --allow-star-activation",
    "vscode:publish": "vsce publish --allow-star-activation"
  },
  "devDependencies": {
    "@types/glob": "7.2.0",
    "@types/ip": "1.1.3",
    "@types/mocha": "7.0.2",
    "@types/node": "12.20.55",
    "@types/qrcode": "1.5.6",
    "@types/vscode": "1.42.0",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.9.2",
    "eslint": "8.57.1",
    "glob": "7.2.3",
    "mocha": "7.2.0",
    "typescript": "5.3.3",
    "vscode-test": "1.6.1"
  },
  "dependencies": {
    "delay": "4.4.1",
    "execa": "4.1.0",
    "ip": "1.1.9",
    "open": "7.4.2",
    "qrcode": "1.5.4"
  }
}